{
  "name": "cv",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vp build",
    "check": "v fmt -verify . && vp check && knip",
    "dev": "conc \"v -d veb_livereload watch --only-watch=*.v,*.html,*.css,*.ts,*.md,*.tr run .\" \"bun vp dev\"",
    "fix": "knip --fix && vp check --fix",
    "prepare": "vp config && gitmoji -i && bun scripts/patch-gitmoji-hook.ts",
    "preview": "bun run build && bun run serve",
    "prod": "bun run build && v -prod .",
    "serve": "v run ."
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "gitmoji-cli": "^9.7.0",
    "knip": "^6.25.0",
    "tailwindcss": "^4.3.2",
    "v-vite": "^0.0.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4"
  },
  "peerDependencies": {
    "typescript": "^7.0.2"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  }
}
